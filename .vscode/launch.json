{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Train main_CD.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main_CD.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--train",
                "--fusion_method", "gated",
                "--mmcosine", "True",
                "--scaling", "10",
                "--dataset", "CREMAD",
                "--visual_path", "./data/CREMAD/Image-01-FPS",
                "--audio_path", "./data/CREMAD/AudioWAV",
                "--stat_path", "./data/CREMAD/stat.csv", 
                "--train_txt", "./data/CREMAD/train.csv",
                "--test_txt", "./data/CREMAD/test.csv",
            ]
        }
    ]
}
